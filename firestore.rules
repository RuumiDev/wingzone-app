rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - authenticated users can read their own data, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Restaurant Locations - Read only
    match /restaurantLocations/{locationId} {
      allow read: if true;
      allow write: if false; // Admin only via console
    }
    
    // Home Banners - Public read access for app home screen
    match /homeBanners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin only
    }
    
    // Menu Items - Public read access for browsing (write restricted to admins)
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin only
    }
    
    // Settings - Public read access for availability and app configuration
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null; // Admin only
    }
    
    // Lobbies
    match /lobbies/{lobbyId} {
      // Anyone can read active lobbies
      allow read: if resource.data.status == 'active';
      
      // Authenticated users can create lobbies
      allow create: if request.auth != null
        && request.resource.data.hostUserId == request.auth.uid
        && request.resource.data.status == 'active';
      
      // Host or members can update lobby
      allow update: if request.auth != null
        && (resource.data.hostUserId == request.auth.uid
            || isMemberOfLobby(request.auth.uid));
      
      // Host can delete lobby
      allow delete: if request.auth != null
        && resource.data.hostUserId == request.auth.uid;
      
      function isMemberOfLobby(userId) {
        return userId in resource.data.members;
      }
    }
    
    // Reviews - Public read for enabled reviews, authenticated write
    match /reviews/{reviewId} {
      // Public can read enabled and approved reviews
      allow read: if resource.data.isEnabled == true 
        && resource.data.moderationStatus == 'approved';
      
      // Authenticated users can create reviews for their own orders
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isEnabled == true
        && request.resource.data.moderationStatus == 'approved';
      
      // Only review owner can read their own reviews (even if disabled)
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      
      // Admins can update and delete (via admin dashboard)
      allow update, delete: if request.auth != null;
    }
    
    // All other collections - allow authenticated access for development
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
